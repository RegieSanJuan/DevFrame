# Local app origin. In Vercel Preview, you can leave NEXT_PUBLIC_APP_URL unset
# and this repo will fall back to the generated branch/deployment URL automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional CSV of allowed origins for Clerk's authorizedParties check.
# Defaults to NEXT_PUBLIC_APP_URL plus the current Vercel deployment URLs when left blank.
CLERK_AUTHORIZED_PARTIES=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-only debug flag. Set to true to expose setup diagnostics.
DEVFRAME_SHOW_SETUP_STATUS=false

# Optional durable production rate limiting.
# Without Redis/KV, DevFrame uses an in-memory dev-only fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Or Vercel KV-compatible env vars:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional Postgres connection strings for Supabase CLI or ORMs.
# Use the session pooler URL for general CLI access on IPv4 networks.
DATABASE_URL=

# Use the direct URL when your network supports IPv6 and you want a direct Postgres connection.
DIRECT_URL=
